# Funcle backend environment variables (copy to .env for local dev; never commit .env)

# HTTP port the Express server listens on
PORT=3000

# Path to the SQLite database file (relative to backend/, or absolute)
DB_PATH=./data/funcle.db

# Secret used to sign JWTs (admin + user session tokens). Use a long random string.
JWT_SECRET=change-me-to-a-long-random-secret

# Admin page password, stored as a BCRYPT HASH (never the plaintext).
# Generate with: node -e "console.log(require('bcrypt').hashSync('your-password', 10))"
ADMIN_PASSWORD=$2b$10$replace-with-a-real-bcrypt-hash

# Production only: directory of the built frontend (frontend/dist) for
# single-origin serving (spec §15). Leave unset in dev (Vite proxies /api).
# STATIC_DIR=./public
